{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Requests / sec (api)",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api\"}[1m]))",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "type": "stat",
      "title": "p99 latency (api)",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
    },
    {
      "type": "stat",
      "title": "Error rate (5xx)",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"api\"}[5m]))",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
    },
    {
      "type": "stat",
      "title": "LLM cost today ($)",
      "targets": [
        {
          "expr": "sum(increase(llm_cost_usd_total[24h]))",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}
    },
    {
      "type": "timeseries",
      "title": "Requests by route",
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{service=\"api\"}[1m]))",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ],
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))",
          "legendFormat": "p50",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))",
          "legendFormat": "p95",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))",
          "legendFormat": "p99",
          "datasource": {"type": "prometheus", "uid": "Prometheus"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}
    },
    {
      "type": "logs",
      "title": "Recent API logs (Loki)",
      "targets": [
        {
          "expr": "{service=\"api\"} | json",
          "datasource": {"type": "loki", "uid": "Loki"}
        }
      ],
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 10}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["evercurrent"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "EverCurrent",
  "uid": "evercurrent",
  "version": 1
}
