# Copy to `.env` (gitignored) and fill in real values before `make up`.

# Postgres connection (asyncpg).
DATABASE_URL=postgresql+asyncpg://evercurrent:evercurrent@postgres:5432/evercurrent
# Redis: Celery broker + result backend + SSE pub/sub.
REDIS_URL=redis://redis:6379/0

# Log level (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO

# Auth0 tenant domain (e.g. dev-abc123.us.auth0.com).
AUTH0_DOMAIN=
# Auth0 API audience.
AUTH0_AUDIENCE=https://api.evercurrent.local
# Auth0 application client id.
AUTH0_CLIENT_ID=
# Auth0 application client secret.
AUTH0_CLIENT_SECRET=
# Next.js SDK session secret (32+ random chars).
AUTH0_SECRET=

# Anthropic API key (Claude Sonnet 4.6 + Haiku 4.5).
ANTHROPIC_API_KEY=
# Voyage AI API key (voyage-3-lite, 512-dim embeddings).
VOYAGE_API_KEY=

# Slack app OAuth client id.
SLACK_CLIENT_ID=
# Slack app OAuth client secret.
SLACK_CLIENT_SECRET=
# Slack request-signing secret (webhook verification).
SLACK_SIGNING_SECRET=

# Dropbox app OAuth client id.
DROPBOX_CLIENT_ID=
# Dropbox app OAuth client secret.
DROPBOX_CLIENT_SECRET=
# Dropbox OAuth redirect URI (must match the app config exactly).
DROPBOX_REDIRECT_URI=http://localhost:8080/api/v1/connectors/dropbox/oauth/callback

# Public base URL for Slack webhooks in dev (ngrok); optional.
WEBHOOK_PUBLIC_URL=

# Fernet key for encrypting connector tokens (base64 32 bytes).
CONNECTOR_SECRET_KEY=

# Browser-facing API base, served via nginx (relative).
NEXT_PUBLIC_API_URL=/api
# Public app URL.
NEXT_PUBLIC_APP_URL=http://localhost:8080
# Absolute API URL for Next server components inside the compose network.
INTERNAL_API_URL=http://api:8000
