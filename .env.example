# EverCurrent — environment variables
# Copy to `.env` (gitignored) and fill in real values before `make up`.

# --- Database + cache (docker-compose defaults; usually no change) ------------
DATABASE_URL=postgresql+asyncpg://evercurrent:evercurrent@postgres:5432/evercurrent
REDIS_URL=redis://redis:6379/0

# --- Logging / observability -------------------------------------------------
LOG_LEVEL=INFO
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Auth0 (Phase 2) ----------------------------------------------------------
# Sign up at https://manage.auth0.com → create a Regular Web Application.
# Domain looks like: dev-abc123.us.auth0.com
AUTH0_DOMAIN=
AUTH0_AUDIENCE=https://api.evercurrent.local
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Used by the Next.js SDK; 32+ random chars
AUTH0_SECRET=

# --- LLM + embeddings --------------------------------------------------------
# Anthropic API key (Claude Sonnet 4.6 + Haiku 4.5)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Voyage AI API key (voyage-3-lite, 512-dim embeddings)
# https://dash.voyageai.com/
VOYAGE_API_KEY=

# --- Slack (Phase 3) ---------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# --- Dropbox connector -------------------------------------------------------
# https://www.dropbox.com/developers/apps → create app → Scoped access
# Scopes: files.metadata.read, files.content.read
# Redirect URI must match exactly: http://localhost:8080/api/v1/connectors/dropbox/oauth/callback
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8080/api/v1/connectors/dropbox/oauth/callback

# --- Google Drive (Phase 10, optional) ---------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/connectors/drive/oauth/callback

# --- Webhook public URL (Slack + Drive in dev via ngrok, optional) -----------
WEBHOOK_PUBLIC_URL=

# --- Connector token encryption (Fernet key, base64 32 bytes) ----------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_SECRET_KEY=

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=http://localhost:8080
