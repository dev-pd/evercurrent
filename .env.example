# EverCurrent — environment variables
# Copy to `.env` (gitignored) and fill in real values before `make up` /
# `docker compose up`.

# --- LLM + embeddings ---------------------------------------------------------
# Anthropic API key (Claude Sonnet 4.6 + Haiku 4.5).
# Get one at https://console.anthropic.com/ -> API Keys.
ANTHROPIC_API_KEY=

# Voyage AI API key (voyage-3-lite, 512-dim embeddings).
# Get one at https://dash.voyageai.com/ -> API Keys.
VOYAGE_API_KEY=

# --- Database -----------------------------------------------------------------
# Postgres connection used by both the API and the worker. The default points
# at the docker-compose `postgres` service.
DATABASE_URL=postgresql+asyncpg://evercurrent:evercurrent@postgres:5432/evercurrent

# --- Cache + queue ------------------------------------------------------------
# Redis used as both an Arq broker and an application cache.
REDIS_URL=redis://redis:6379/0

# --- Frontend -----------------------------------------------------------------
# Base URL the web app uses to reach the API. Nginx routes /api/* to the
# backend, so the frontend talks to itself via a relative path in compose.
NEXT_PUBLIC_API_URL=/api

# --- Logging / observability --------------------------------------------------
LOG_LEVEL=INFO
# Optional: leave unset locally to keep OTel as a no-op exporter.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
